# Copy this file to ".env" and fill in your key to enable optional LLM checks.
# Cleanvey works fully WITHOUT this — rule-based checks run regardless.

# Anthropic Claude API key (optional). Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Model used for semantic checks (optional, has a sensible default)
CLEANVEY_LLM_MODEL=claude-haiku-4-5-20251001
