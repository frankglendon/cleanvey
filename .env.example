# Copy this file to ".env" and fill in your key. The LLM "judge" is a core
# layer of Cleanvey — set this to run the full pipeline.
# (Advanced users can still disable the LLM rule in config/default_rules.yaml.)
# 复制本文件为 ".env" 并填入你的 key。LLM “判官”是 Cleanvey 的核心一层——
# 配置后即可运行完整流程。（进阶用户也可在 config/default_rules.yaml 关闭该 LLM 规则。）

# Anthropic Claude API key. Get one at https://console.anthropic.com/
# Anthropic Claude API key，在上面网址申请。
ANTHROPIC_API_KEY=

# Model used by the judge (has a sensible default) / 判官使用的模型（有合理默认值）
CLEANVEY_LLM_MODEL=claude-haiku-4-5-20251001
